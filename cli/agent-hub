#!/bin/bash
# Agent Hub CLI Launcher
# Usage: ./agent-hub <command> [options]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_SCRIPT="$SCRIPT_DIR/agent-hub-cli.py"

if [ ! -f "$CLI_SCRIPT" ]; then
    echo "Error: CLI script not found at $CLI_SCRIPT"
    exit 1
fi

python3 "$CLI_SCRIPT" "$@"
